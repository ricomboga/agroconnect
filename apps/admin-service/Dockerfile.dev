FROM node:20-alpine
WORKDIR /workspace
RUN apk add --no-cache openssl
RUN corepack enable && corepack prepare pnpm@9.4.0 --activate

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/kafka/package.json    ./packages/kafka/
COPY packages/shared/package.json   ./packages/shared/
COPY apps/admin-service/package.json ./apps/admin-service/

RUN pnpm install --filter @agroconnect/admin-service... --no-frozen-lockfile

COPY tsconfig.base.json ./
COPY packages/ ./packages/
COPY apps/admin-service/ ./apps/admin-service/

WORKDIR /workspace/apps/admin-service
EXPOSE 3011
CMD ["npx", "tsx", "src/index.ts"]
