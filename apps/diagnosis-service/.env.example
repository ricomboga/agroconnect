MONGODB_URI=mongodb://localhost:27017/diagnosis_db
KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=diagnosis-service-consumer
PORT=8000

# AI provider: 'claude' (default) | 'google-vision' | 'mock'
INFERENCE_PROVIDER=claude

# Claude (required when INFERENCE_PROVIDER=claude)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Google Vision (only used when INFERENCE_PROVIDER=google-vision)
GOOGLE_APPLICATION_CREDENTIALS=

# Confidence tiers surfaced to the mobile UI as diagnosis.confidence_tier
MIN_CONFIDENCE=0.60
CONFIDENCE_HIGH_THRESHOLD=0.80

# Per-farmer daily rate limit on diagnosis submissions
REDIS_URL=redis://localhost:6379
DIAGNOSIS_RATE_LIMIT_MAX=20
DIAGNOSIS_RATE_LIMIT_WINDOW_SECONDS=86400

NODE_ENV=development
