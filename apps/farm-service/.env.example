NODE_ENV=development
SERVICE_NAME=farm-service
LOG_LEVEL=debug
PORT=3001

# PostgreSQL — farm_db
DATABASE_URL=postgresql://agroconnect:agroconnect_dev@localhost:5433/farm_db

# Kafka (use external listener when running service on host)
KAFKA_BROKERS=localhost:9094

# Redis
REDIS_URL=redis://:redis_dev_password@localhost:6379

# JWT (RS256 public key from auth-service)
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"

# Sentry (optional in dev)
SENTRY_DSN=

# FCM (optional in dev)
FCM_SERVER_KEY=
