PORT=3001
NODE_ENV=development
LOG_LEVEL=info
SERVICE_NAME=farm-service

# PostgreSQL connection for farm_db
DATABASE_URL=postgresql://postgres:password@localhost:5432/farm_db

# RSA public key used to verify JWTs issued by auth-service (newlines as \n)
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Kafka broker addresses (comma-separated)
KAFKA_BROKERS=localhost:9092

# Redis connection (used for caching in future phases)
REDIS_URL=redis://localhost:6379

# Internal base URL of media-service (no trailing slash)
MEDIA_SERVICE_URL=http://localhost:3010
