NOTIFICATION_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/notification_db
KAFKA_BROKERS=localhost:9092
FCM_SERVICE_ACCOUNT=
GOOGLE_APPLICATION_CREDENTIALS=
AT_API_KEY=
AT_USERNAME=
# Optional: alphanumeric sender ID / shortcode registered with Africa's Talking.
# Leave unset to use the sandbox/default sender.
AT_SENDER_ID=
LOG_LEVEL=info
SERVICE_NAME=notification-service
NODE_ENV=development
PORT=3007

# RSA public key used to verify JWTs issued by auth-service (newlines as \n).
# Must be set — without it every authenticated /notifications endpoint 401s,
# even though the token is valid (verification fails, not expiry).
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
