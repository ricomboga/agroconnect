FARM_SERVICE_URL=http://localhost:3001
KAFKA_BROKERS=localhost:9092
REDIS_URL=redis://localhost:6379
REST_PORT=8002
LOG_LEVEL=info
FARM_SERVICE_TIMEOUT_S=5
SENTRY_DSN=

# RSA public key used to verify JWTs issued by auth-service (newlines as \n).
# Must be set — without it every /predict/* endpoint 401s.
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
