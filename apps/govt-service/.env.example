PORT=3006
NODE_ENV=development
LOG_LEVEL=info
SERVICE_NAME=govt-service

# PostgreSQL connection for govt_db
DATABASE_URL=postgresql://postgres:password@localhost:5432/govt_db

# RSA public key used to verify JWTs issued by auth-service (newlines as \n)
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Kafka broker addresses (comma-separated)
KAFKA_BROKERS=localhost:9092

# Internal base URL of media-service (no trailing slash)
MEDIA_SERVICE_URL=http://localhost:3009
