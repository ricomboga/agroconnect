FROM node:20-alpine
WORKDIR /workspace
RUN apk add --no-cache openssl
RUN corepack enable && corepack prepare pnpm@9.4.0 --activate

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/db/package.json       ./packages/db/
COPY packages/shared/package.json   ./packages/shared/
COPY apps/soil-service/package.json ./apps/soil-service/

RUN pnpm install --filter @agroconnect/soil-service... --no-frozen-lockfile

COPY tsconfig.base.json ./
COPY packages/ ./packages/
COPY apps/soil-service/ ./apps/soil-service/

RUN pnpm --filter @agroconnect/db generate:soil

WORKDIR /workspace/apps/soil-service
EXPOSE 3002
CMD ["npx", "tsx", "src/index.ts"]
