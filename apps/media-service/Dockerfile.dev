FROM node:20-alpine
WORKDIR /workspace
RUN apk add --no-cache openssl
RUN corepack enable && corepack prepare pnpm@9.4.0 --activate

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/shared/package.json   ./packages/shared/
COPY apps/media-service/package.json ./apps/media-service/

RUN pnpm install --filter @agroconnect/media-service --no-frozen-lockfile

COPY tsconfig.base.json ./
COPY packages/shared/ ./packages/shared/
COPY apps/media-service/ ./apps/media-service/

WORKDIR /workspace/apps/media-service
EXPOSE 3009
CMD ["npx", "tsx", "src/index.ts"]
