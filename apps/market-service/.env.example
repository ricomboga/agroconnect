PORT=3004
NODE_ENV=development
LOG_LEVEL=info
SERVICE_NAME=market-service

# PostgreSQL connection for market_db
MARKET_DATABASE_URL=postgresql://postgres:password@localhost:5432/market_db

# RSA public key used to verify JWTs issued by auth-service (newlines as \n)
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Kafka broker addresses (comma-separated)
KAFKA_BROKERS=localhost:9092

# Internal base URL of farm-service (no trailing slash)
FARM_SERVICE_URL=http://localhost:3001
