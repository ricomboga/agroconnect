FROM node:20-alpine
WORKDIR /workspace
RUN apk add --no-cache openssl
RUN corepack enable && corepack prepare pnpm@9.4.0 --activate

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/db/package.json       ./packages/db/
COPY packages/kafka/package.json    ./packages/kafka/
COPY packages/shared/package.json   ./packages/shared/
COPY apps/market-service/package.json ./apps/market-service/

RUN pnpm install --filter @agroconnect/market-service... --no-frozen-lockfile

COPY tsconfig.base.json ./
COPY packages/ ./packages/
COPY apps/market-service/ ./apps/market-service/

RUN pnpm --filter @agroconnect/db generate:market

WORKDIR /workspace/apps/market-service
EXPOSE 3004
CMD ["npx", "tsx", "src/index.ts"]
