FROM node:20-alpine
WORKDIR /workspace
RUN apk add --no-cache openssl
RUN corepack enable && corepack prepare pnpm@9.4.0 --activate

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/db/package.json       ./packages/db/
COPY packages/kafka/package.json    ./packages/kafka/
COPY packages/shared/package.json   ./packages/shared/
COPY apps/finance-service/package.json ./apps/finance-service/

RUN pnpm install --filter @agroconnect/finance-service... --no-frozen-lockfile

COPY tsconfig.base.json ./
COPY packages/ ./packages/
COPY apps/finance-service/ ./apps/finance-service/

RUN pnpm --filter @agroconnect/db generate:finance

WORKDIR /workspace/apps/finance-service
EXPOSE 3003
CMD ["npx", "tsx", "src/index.ts"]
