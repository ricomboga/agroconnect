PORT=3003
NODE_ENV=development
LOG_LEVEL=info
SERVICE_NAME=finance-service

# PostgreSQL connection for finance_db
DATABASE_URL=postgresql://postgres:password@localhost:5432/finance_db

# RSA public key used to verify JWTs issued by auth-service (newlines as \n)
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Kafka broker addresses (comma-separated)
KAFKA_BROKERS=localhost:9092

# Internal base URL of farm-service (no trailing slash)
FARM_SERVICE_URL=http://localhost:3001

# Safaricom M-Pesa IP allowlist (comma-separated CIDR blocks or exact IPs)
SAFARICOM_IP_ALLOWLIST=196.201.214.0/24,196.201.215.0/24

# Shared HMAC secret for M-Pesa callback signature validation
MPESA_CALLBACK_SECRET=change-me-in-production
