# Base URL of the API gateway (proxies to all backend services) — exposed to browser
NEXT_PUBLIC_API_URL=http://localhost:3000

# Server-to-server URLs (never exposed to the browser)
AUTH_SERVICE_URL=http://localhost:3001
FINANCE_SERVICE_URL=http://localhost:3003
MARKET_SERVICE_URL=http://localhost:3004
GOVT_SERVICE_URL=http://localhost:3006

# RS256 public key (PEM) from the auth-service — used to verify JWTs in middleware
# Copy the public key from HashiCorp Vault: secret/auth-service/jwt_public_key
AUTH_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
<paste RSA 4096-bit public key here>
-----END PUBLIC KEY-----"
