# ─── Common (all Node.js services) ───────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

DATABASE_URL=postgresql://agroconnect:agroconnect_dev@localhost:5433/REPLACE_WITH_SERVICE_DB
KAFKA_BROKERS=localhost:9094
REDIS_URL=redis://:redis_dev_password@localhost:6379
SENTRY_DSN=
FCM_SERVER_KEY=

# ─── auth-service ─────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nREPLACE_ME\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ─── finance-service ──────────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=REPLACE_ME
MPESA_CONSUMER_SECRET=REPLACE_ME
MPESA_SHORTCODE=REPLACE_ME
MPESA_PASSKEY=REPLACE_ME
MPESA_CALLBACK_URL=https://api.agroconnect.africa/api/v1/finance/mpesa/callback
MPESA_ENV=sandbox

# ─── notification-service / ussd-service ──────────────────────────────────────
AT_API_KEY=REPLACE_ME
AT_USERNAME=sandbox

# ─── media-service ────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_REGION=af-south-1
S3_BUCKET_NAME=agroconnect-media-dev
CDN_BASE_URL=https://media.agroconnect.africa

# ─── weather-service / predict-service ───────────────────────────────────────
OPENWEATHER_API_KEY=REPLACE_ME
NASA_POWER_API_KEY=REPLACE_ME
KMD_API_KEY=REPLACE_ME

# ─── diagnosis-service ────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/diagnosis_db
MODEL_SERVING_URL=http://tf-serving:8501
MODEL_VERSION=latest
MIN_CONFIDENCE=0.65
