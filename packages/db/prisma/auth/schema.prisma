generator client {
  provider      = "prisma-client-js"
  output        = "../../generated/auth-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("AUTH_DATABASE_URL")
}

model User {
  id            String     @id @default(uuid())
  phone         String     @unique
  email         String?    @unique
  passwordHash  String
  fullName      String
  role          UserRole
  partnerBankId String?
  county        String?
  subCounty     String?
  language      Language   @default(sw)
  status        UserStatus @default(pending_verification)
  isSuperAdmin  Boolean    @default(false)
  staffRole     StaffRole  @default(admin)
  kycStatus     KycStatus  @default(pending)
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  sessions      Session[]

  // Maker-checker: who created this account, and who verified it.
  // The verifier can never be the same user as the creator (enforced in the service layer).
  createdByUserId String?
  createdBy        User?   @relation("UserCreatedBy", fields: [createdByUserId], references: [id])
  createdUsers     User[]  @relation("UserCreatedBy")

  verifiedByUserId String?
  verifiedBy        User?  @relation("UserVerifiedBy", fields: [verifiedByUserId], references: [id])
  verifiedUsers      User[] @relation("UserVerifiedBy")
  verifiedAt        DateTime?

  // Supervisor of this staff/field-agent user. When a field agent (e.g. extension_officer)
  // creates a farmer, only that field agent's supervisor may verify the farmer.
  supervisorId String?
  supervisor    User?   @relation("UserSupervisor", fields: [supervisorId], references: [id])
  supervisees   User[]  @relation("UserSupervisor")

  roleAssignments      UserRoleAssignment[] @relation("UserRoleAssignments")
  roleAssignmentsMade  UserRoleAssignment[] @relation("RoleAssignedBy")

  @@index([createdByUserId])
  @@index([supervisorId])
  @@index([status])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  permissions RolePermission[]
  assignments UserRoleAssignment[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRoleAssignment {
  id               String   @id @default(uuid())
  userId           String
  roleId           String
  assignedByUserId String?
  assignedAt       DateTime @default(now())

  user       User  @relation("UserRoleAssignments", fields: [userId], references: [id], onDelete: Cascade)
  role       Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedBy User? @relation("RoleAssignedBy", fields: [assignedByUserId], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@map("user_role_assignments")
}

model Session {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId         String?
  refreshTokenHash String
  ipAddress        String
  userAgent        String?
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  @@index([userId])
  @@map("sessions")
}

model ServiceProvider {
  id                 String             @id @default(uuid())
  userId             String             @unique
  type               ProviderType
  registrationNumber String
  issuingBody        String
  specialisations    Json
  countiesServed     Json
  bio                String
  profilePhotoUrl    String?
  verificationStatus VerificationStatus @default(pending)
  verificationDocs   Json?
  maxFarmers         Int                @default(50)
  ratingAvg          Decimal            @default(0) @db.Decimal(3, 2)
  ratingCount        Int                @default(0)
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())

  @@map("service_providers")
}

model FarmerExpertAssignment {
  id           String   @id @default(uuid())
  farmerId     String   @unique
  expertId     String
  assignedAt   DateTime @default(now())

  @@index([expertId])
  @@map("farmer_expert_assignments")
}

model AuditLog {
  id        String   @id @default(uuid())
  actor     String
  action    String
  category  String
  refId     String?
  note      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("audit_logs")
}

model KycDocument {
  id         String        @id @default(uuid())
  userId     String
  type       KycDocType
  url        String
  status     KycDocStatus  @default(pending)
  uploadedAt DateTime      @default(now())

  @@index([userId])
  @@map("kyc_documents")
}

model KycHistoryEntry {
  id        String   @id @default(uuid())
  userId    String
  action    String
  actor     String
  note      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("kyc_history_entries")
}

enum KycDocType {
  national_id
  business_cert
  kvb_licence
  pcpb_licence
  other
}

enum KycDocStatus {
  pending
  approved
  rejected
}

enum ProviderType {
  extension_officer
  vet_officer
  agronomist
  soil_lab
  equipment_dealer
}

enum VerificationStatus {
  pending
  verified
  rejected
  suspended
}

enum UserRole {
  farmer
  extension_officer
  vet_officer
  supplier
  buyer
  govt_officer
  admin
  lender
  farm_worker
}

enum Language {
  sw
  en
}

enum StaffRole {
  admin
  county_admin
  moderator
}

enum KycStatus {
  pending
  submitted
  verified
  rejected
}

enum UserStatus {
  pending_verification
  verified
  active
  inactive
  disabled
  deleted
}
