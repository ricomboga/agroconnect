generator client {
  provider      = "prisma-client-js"
  output        = "../../generated/finance-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model InputDistribution {
  id            String   @id @default(uuid())
  partnerId     String
  farmerId      String
  inputType     String
  valueKes      Decimal  @db.Decimal(12, 2)
  distributedAt DateTime
  createdAt     DateTime @default(now())

  @@index([partnerId])
  @@index([farmerId])
  @@map("input_distributions")
}

model CreditScore {
  id                      String     @id @default(uuid())
  farmerId                String     @unique
  score                   Decimal    @db.Decimal(5, 2)
  band                    CreditBand
  maxLoanKes              Decimal    @db.Decimal(12, 2)
  seasonsOfData           Int
  avgYieldScore           Decimal    @db.Decimal(5, 2)
  inputManagementScore    Decimal    @db.Decimal(5, 2)
  activityComplianceScore Decimal    @db.Decimal(5, 2)
  platformEngagementScore Decimal    @db.Decimal(5, 2)
  computedAt              DateTime

  @@map("credit_scores")
}

model LoanApplication {
  id                   String         @id @default(uuid())
  farmerId             String
  farmId               String
  type                 LoanType
  amountRequestedKes   Decimal        @db.Decimal(12, 2)
  purpose              String
  repaymentMonths      Int
  partnerBankId        String?
  creditScore          Decimal?       @db.Decimal(5, 2)
  creditBand           CreditBand?
  farmGpsLat           Decimal?       @db.Decimal(9, 6)
  farmGpsLng           Decimal?       @db.Decimal(9, 6)
  status               LoanStatus     @default(draft)
  approvedAmountKes    Decimal?       @db.Decimal(12, 2)
  interestRatePct      Decimal?       @db.Decimal(5, 2)
  disbursedAt          DateTime?
  mpesaDisbursementRef String?
  rejectionReason      String?
  submittedAt          DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  documents            LoanDocument[]

  @@index([farmerId])
  @@map("loan_applications")
}

model LoanDocument {
  id           String          @id @default(uuid())
  loanId       String
  loan         LoanApplication @relation(fields: [loanId], references: [id], onDelete: Cascade)
  name         String
  documentType LoanDocType
  storageKey   String
  mimeType     String          @default("application/octet-stream")
  sizeBytes    Int             @default(0)
  uploadedAt   DateTime        @default(now())

  @@index([loanId])
  @@map("loan_documents")
}

enum CreditBand {
  A
  B
  C
  D
  ineligible
}

enum LoanType {
  agricultural_working_capital
  back_to_school
  asset_finance
  emergency
}

enum LoanStatus {
  draft
  submitted
  under_review
  approved
  rejected
  disbursed
  cancelled
  repaid
  defaulted
}

enum LoanDocType {
  national_id
  land_title
  farm_photo
  bank_statement
  payslip
  other
}

enum PartnerType {
  bank
  microfinance
  sacco
  mobile_lender
  ngo_grant
  cooperative
}

enum LoanCategory {
  back_to_school
  farm_input
  asset_finance
  emergency
  general
}

enum TxType {
  income
  expense
}

model LoanPartner {
  id                 String        @id
  name               String
  type               PartnerType
  description        String?
  logoUrl            String?
  licenceNo          String?
  paybill            String?
  headOfficeCounty   String?
  headOfficeSubCounty String?
  // Counties an NGO/grant institution operates in — determines which farmers
  // (by farm location) show up in their farmer roster, reports and dashboard.
  // Not applicable to bank/MFI/sacco/mobile_lender partners.
  operatingCounties  String[]      @default([])
  minLoanKes         Decimal       @db.Decimal(12, 2)
  maxLoanKes         Decimal       @db.Decimal(12, 2)
  processingDays     Int
  activeFarmers      Int           @default(0)
  repaymentRatePct   Decimal       @default(0) @db.Decimal(5, 2)
  interestRateAnnual Decimal       @default(0) @db.Decimal(5, 2)
  active             Boolean       @default(true)
  createdAt          DateTime      @default(now())
  products           LoanProduct[]

  @@map("loan_partners")
}

model FarmerLenderAssignment {
  id         String   @id @default(uuid())
  farmerId   String   @unique
  lenderId   String
  assignedAt DateTime @default(now())

  @@map("farmer_lender_assignments")
}

model LoanProduct {
  id              String       @id
  partnerId       String
  partner         LoanPartner  @relation(fields: [partnerId], references: [id])
  name            String
  category        LoanCategory
  description     String?
  interestRate    Decimal      @db.Decimal(5, 2)
  minAmountKes    Decimal      @db.Decimal(12, 2)
  maxAmountKes    Decimal      @db.Decimal(12, 2)
  repaymentMonths Int
  eligibilityBand CreditBand
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())

  @@index([partnerId])
  @@map("loan_products")
}

model Transaction {
  id            String   @id @default(uuid())
  farmerId      String
  type          TxType
  amountKes     Decimal  @db.Decimal(12, 2)
  category      String
  linkedTo      String?
  buyerSupplier String?
  date          String
  notes         String?
  createdAt     DateTime @default(now())

  @@index([farmerId])
  @@map("transactions")
}
