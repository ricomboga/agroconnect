generator client {
  provider      = "prisma-client-js"
  output        = "../../generated/market-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("MARKET_DATABASE_URL")
}

model ProduceListing {
  id                  String        @id @default(uuid())
  farmerId            String
  farmId              String
  harvestId           String?
  crop                String
  variety             String?
  quantityKg          Decimal       @db.Decimal(10, 2)
  askingPriceKes      Decimal       @db.Decimal(8, 2)
  qualityGrade        QualityGrade
  availableFrom       DateTime      @db.Date
  availableUntil      DateTime      @db.Date
  locationCounty      String
  locationDescription String?
  photos              Json?
  status              ListingStatus @default(active)
  views               Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([farmerId, status])
  @@index([crop, locationCounty, status])
  @@index([availableFrom, availableUntil])
  @@map("produce_listings")
}

model SupplierProduct {
  id                 String          @id @default(uuid())
  supplierId         String
  name               String
  category           ProductCategory
  brand              String?
  description        String
  unit               String
  pricePerUnitKes    Decimal         @db.Decimal(10, 2)
  stockQuantity      Decimal         @db.Decimal(10, 2)
  sku                String?         @unique
  countyAvailability Json
  photos             Json?
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([supplierId, isActive])
  @@index([category, isActive])
  @@map("supplier_products")
}

model Order {
  id              String      @id @default(uuid())
  buyerId         String
  supplierId      String
  productId       String
  quantityUnits   Decimal     @db.Decimal(10, 2)
  unitPriceKes    Decimal     @db.Decimal(10, 2)
  totalPriceKes   Decimal     @db.Decimal(12, 2)
  deliveryAddress String
  notes           String?
  status          OrderStatus @default(pending)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([buyerId, status])
  @@index([supplierId, status])
  @@map("orders")
}

model CommodityPrice {
  id        String   @id @default(uuid())
  crop      String   @unique
  priceKes  Decimal  @db.Decimal(10, 2)
  unit      String   @default("kg")
  updatedAt DateTime @updatedAt

  @@map("commodity_prices")
}

enum QualityGrade {
  A
  B
  C
  reject

  @@map("quality_grade")
}

enum ListingStatus {
  active
  sold
  expired
  withdrawn

  @@map("listing_status")
}

enum ProductCategory {
  seed
  fertiliser
  pesticide
  herbicide
  equipment
  veterinary
  other

  @@map("product_category")
}

enum OrderStatus {
  pending
  confirmed
  dispatched
  delivered

  @@map("order_status")
}
