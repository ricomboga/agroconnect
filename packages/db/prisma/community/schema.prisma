generator client {
  provider      = "prisma-client-js"
  output        = "../../generated/community-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("COMMUNITY_DATABASE_URL")
}

model Thread {
  id        String         @id @default(uuid())
  authorId  String
  category  ThreadCategory
  title     String
  body      String
  cropType  String?
  county    String?
  upvotes   Int            @default(0)
  status    ThreadStatus   @default(active)
  replies   Reply[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([authorId, status])
  @@index([category, status])
  @@map("threads")
}

model Reply {
  id               String      @id @default(uuid())
  threadId         String
  thread           Thread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId         String
  body             String
  upvotes          Int         @default(0)
  isExpertVerified Boolean     @default(false)
  status           ReplyStatus @default(active)
  createdAt        DateTime    @default(now())

  @@index([threadId])
  @@map("replies")
}

enum ThreadCategory {
  crop_advice
  livestock_health
  market_talk
  weather_climate
  finance_business
  government_programs
  success_stories
  equipment_tools

  @@map("thread_category")
}

enum ThreadStatus {
  active
  hidden
  deleted
  flagged

  @@map("thread_status")
}

enum ReplyStatus {
  active
  flagged

  @@map("reply_status")
}
