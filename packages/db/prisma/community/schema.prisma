generator client {
  provider      = "prisma-client-js"
  output        = "../../generated/community-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("COMMUNITY_DATABASE_URL")
}

model Thread {
  id          String         @id @default(uuid())
  authorId    String
  authorName  String
  authorCounty String?
  category    ThreadCategory
  title       String
  body        String
  cropType    String?
  county      String?
  photos      String[]       @default([])
  upvotes     Int            @default(0)
  status      ThreadStatus   @default(active)
  replies     Reply[]
  votes       ThreadVote[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([authorId, status])
  @@index([category, status])
  @@map("threads")
}

model Reply {
  id               String      @id @default(uuid())
  threadId         String
  thread           Thread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId         String
  authorName       String
  authorRole       String?
  body             String
  upvotes          Int         @default(0)
  isExpertVerified Boolean     @default(false)
  status           ReplyStatus @default(active)
  reportReason     String?
  votes            ReplyVote[]
  createdAt        DateTime    @default(now())

  @@index([threadId, status])
  @@map("replies")
}

model ThreadVote {
  userId    String
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, threadId])
  @@map("thread_votes")
}

model ReplyVote {
  userId    String
  replyId   String
  reply     Reply    @relation(fields: [replyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, replyId])
  @@map("reply_votes")
}

model Expert {
  id              String     @id @default(uuid())
  userId          String?    @unique
  name            String
  photoUrl        String?
  providerType    ExpertType
  specialisations String[]   @default([])
  countiesServed  String[]   @default([])
  subCountiesServed String[] @default([])
  organisation    String?
  licenceNumber   String?
  maxFarmers      Int?
  bio             String?
  rating          Float      @default(0)
  reviewCount     Int        @default(0)
  phone           String
  whatsapp        String?
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())

  @@index([providerType, isActive])
  @@map("experts")
}

model Article {
  id          String         @id @default(uuid())
  slug        String         @unique
  title       String
  summary     String
  body        String
  category    ThreadCategory
  type        ArticleType    @default(news)
  startsAt    DateTime?
  endsAt      DateTime?
  joinLink    String?
  location    String?
  authorName  String
  isPublished Boolean        @default(true)
  publishedAt DateTime       @default(now())
  createdAt   DateTime       @default(now())

  @@index([category, isPublished])
  @@index([type, isPublished])
  @@map("articles")
}

enum ArticleType {
  news
  event
  webinar

  @@map("article_type")
}

enum ThreadCategory {
  crop_advice
  livestock_health
  market_talk
  weather_climate
  finance_business
  government_programs
  success_stories
  equipment_tools

  @@map("thread_category")
}

enum ThreadStatus {
  active
  hidden
  deleted
  flagged

  @@map("thread_status")
}

enum ReplyStatus {
  active
  flagged
  deleted

  @@map("reply_status")
}

enum ExpertType {
  agronomist
  vet
  extension_officer
  soil_lab

  @@map("expert_type")
}
