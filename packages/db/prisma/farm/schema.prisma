generator client {
  provider      = "prisma-client-js"
  output        = "../../generated/farm-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Farm {
  id          String        @id @default(uuid())
  ownerId     String
  name        String
  locationLat Decimal       @db.Decimal(10, 7)
  locationLng Decimal       @db.Decimal(10, 7)
  county      String
  subCounty   String?
  areaAcres   Decimal       @db.Decimal(8, 2)
  soilType    SoilType?
  waterSource WaterSource?
  status      FarmStatus    @default(active)
  farmType    FarmType      @default(crop)
  plots       FarmPlot[]
  workers     FarmWorker[]
  activities  Activity[]
  animalGroups AnimalGroup[]
  inputs      Input[]
  harvests    Harvest[]
  inventoryItems        InventoryItem[]
  animalProductRecords  AnimalProductRecord[]
  customerCollections   CustomerCollection[]
  machinery             Machinery[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@index([ownerId, deletedAt])
  @@map("farms")
}

model FarmPlot {
  id                   String    @id @default(uuid())
  farmId               String
  farm                 Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  name                 String
  areaAcres            Decimal   @db.Decimal(6, 2)
  currentCrop          String?
  currentCropPlantedAt DateTime? @db.Date
  polygonGeojson       Json?
  plantingDate         DateTime? @db.Date
  cropVariety          String?

  @@map("farm_plots")
}

model FarmWorker {
  id       String         @id @default(uuid())
  farmId   String
  farm     Farm           @relation(fields: [farmId], references: [id], onDelete: Cascade)
  userId   String
  role     FarmWorkerRole
  addedAt  DateTime       @default(now())
  isActive Boolean        @default(true)

  @@unique([farmId, userId])
  @@index([farmId])
  @@index([userId])
  @@map("farm_workers")
}

model Activity {
  id                  String         @id @default(uuid())
  farmId              String
  farm                Farm           @relation(fields: [farmId], references: [id])
  plotId              String?
  type                ActivityType
  title               String
  description         String?
  scheduledDate       DateTime       @db.Date
  scheduledTime       String?
  completedDate       DateTime?      @db.Date
  status              ActivityStatus @default(pending)
  labourCostKes       Decimal        @default(0) @db.Decimal(10, 2)
  notes               String?
  skipReason          String?
  assignedToWorkerId  String?
  createdAt           DateTime       @default(now())

  @@index([farmId, scheduledDate])
  @@map("activities")
}

model AnimalGroup {
  id         String   @id @default(uuid())
  farmId     String
  farm       Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  animalType String
  count      Int
  breed      String?
  notes      String?
  createdAt  DateTime @default(now())

  @@index([farmId])
  @@map("animal_groups")
}

model Input {
  id           String    @id @default(uuid())
  farmId       String
  farm         Farm      @relation(fields: [farmId], references: [id])
  activityId   String?
  type         InputType
  productName  String
  supplierId   String?
  quantity     Decimal   @db.Decimal(10, 3)
  unit         String
  unitCostKes  Decimal   @db.Decimal(10, 2)
  totalCostKes Decimal   @db.Decimal(12, 2)
  appliedDate  DateTime  @db.Date
  notes        String?

  @@map("inputs")
}

model Harvest {
  id              String        @id @default(uuid())
  farmId          String
  farm            Farm          @relation(fields: [farmId], references: [id])
  plotId          String?
  crop            String
  variety         String?
  quantityKg      Decimal       @db.Decimal(10, 2)
  qualityGrade    QualityGrade?
  harvestDate     DateTime      @db.Date
  storageLocation String?
  soldQuantityKg  Decimal       @default(0) @db.Decimal(10, 2)
  avgPriceKes     Decimal?      @db.Decimal(8, 2)
  totalRevenueKes Decimal?      @db.Decimal(12, 2)
  notes           String?

  @@map("harvests")
}

enum SoilType {
  clay
  loam
  sandy
  silty
  peaty
  chalky
}

enum WaterSource {
  rain
  irrigation
  borehole
  river
  mixed
}

enum FarmStatus {
  active
  fallow
  rented_out
  sold
}

enum FarmType {
  crop
  animal
  both
}

enum FarmWorkerRole {
  manager
  field_worker
  harvester
  sprayer
  driver
}

enum ActivityType {
  planting
  irrigation
  fertilising
  pesticide
  harvesting
  weeding
  other
}

enum ActivityStatus {
  pending
  completed
  skipped
}

enum InputType {
  seed
  fertiliser
  pesticide
  herbicide
  fuel
  equipment
  other
}

enum QualityGrade {
  A
  B
  C
  reject
}

model InventoryItem {
  id                String      @id @default(uuid())
  farmId            String
  farm              Farm        @relation(fields: [farmId], references: [id], onDelete: Cascade)
  name              String
  category          String
  emoji             String
  unit              String
  purchasedQty      Decimal     @db.Decimal(10, 3)
  usedQty           Decimal     @default(0) @db.Decimal(10, 3)
  totalPurchasedQty Decimal     @db.Decimal(10, 3)
  costPerUnit       Decimal     @db.Decimal(10, 2)
  supplier          String
  lastUsedDate      DateTime?   @db.Date
  scheduledUseDate  DateTime?   @db.Date
  notes             String?
  createdAt         DateTime    @default(now())

  @@index([farmId])
  @@map("inventory_items")
}

model AnimalProductRecord {
  id            String   @id @default(uuid())
  farmId        String
  farm          Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  animalGroupId String
  date          DateTime @db.Date
  productType   String
  quantity      Decimal  @db.Decimal(10, 2)
  unit          String
  soldQty       Decimal  @default(0) @db.Decimal(10, 2)
  pricePerUnit  Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())

  @@index([farmId])
  @@map("animal_product_records")
}

model CustomerCollection {
  id            String    @id @default(uuid())
  farmId        String
  farm          Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  customerName  String
  customerPhone String?
  productType   String
  quantity      Decimal   @db.Decimal(10, 2)
  unit          String
  pricePerUnit  Decimal   @db.Decimal(10, 2)
  totalAmount   Decimal   @db.Decimal(12, 2)
  takenDate     DateTime  @db.Date
  paidDate      DateTime? @db.Date
  isPaid        Boolean   @default(false)
  notes         String?
  createdAt     DateTime  @default(now())

  @@index([farmId])
  @@map("customer_collections")
}

model Machinery {
  id          String            @id @default(uuid())
  farmId      String
  farm        Farm              @relation(fields: [farmId], references: [id], onDelete: Cascade)
  name        String
  type        MachineryType
  condition   MachineryCondition @default(good)
  acquiredAt  DateTime          @db.Date
  disposedAt  DateTime?         @db.Date
  notes       String?
  createdAt   DateTime          @default(now())

  @@index([farmId])
  @@map("machinery")
}

enum MachineryType {
  irrigation
  tillage
  spraying
  harvesting
  transport
  processing
  other
}

enum MachineryCondition {
  good
  fair
  worn
  broken
}
